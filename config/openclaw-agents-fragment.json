{
  "agents": {
    "defaults": {
      "model": {
        "primary": "YOUR_DEFAULT_MODEL"
      },
      "compaction": {
        "mode": "safeguard"
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "主编排",
        "workspace": "~/.openclaw/workspace-main",
        "agentDir": "~/.openclaw/agents/main/agent"
      },
      {
        "id": "pm",
        "name": "产品",
        "workspace": "~/.openclaw/workspace-pm",
        "agentDir": "~/.openclaw/agents/pm/agent"
      },
      {
        "id": "design",
        "name": "设计",
        "workspace": "~/.openclaw/workspace-design",
        "agentDir": "~/.openclaw/agents/design/agent"
      },
      {
        "id": "dev",
        "name": "开发",
        "workspace": "~/.openclaw/workspace-dev",
        "agentDir": "~/.openclaw/agents/dev/agent"
      },
      {
        "id": "ops",
        "name": "运维",
        "workspace": "~/.openclaw/workspace-ops",
        "agentDir": "~/.openclaw/agents/ops/agent"
      },
      {
        "id": "blog",
        "name": "博客",
        "workspace": "~/.openclaw/workspace-blog",
        "agentDir": "~/.openclaw/agents/blog/agent"
      },
      {
        "id": "project-manager",
        "name": "项目经理",
        "workspace": "~/.openclaw/workspace-project-manager",
        "agentDir": "~/.openclaw/agents/project-manager/agent"
      },
      {
        "id": "product-manager",
        "name": "产品经理",
        "workspace": "~/.openclaw/workspace-product-manager",
        "agentDir": "~/.openclaw/agents/product-manager/agent"
      },
      {
        "id": "system-architect",
        "name": "系统架构师",
        "workspace": "~/.openclaw/workspace-system-architect",
        "agentDir": "~/.openclaw/agents/system-architect/agent"
      },
      {
        "id": "domain-expert",
        "name": "领域专家",
        "workspace": "~/.openclaw/workspace-domain-expert",
        "agentDir": "~/.openclaw/agents/domain-expert/agent"
      },
      {
        "id": "ux-designer",
        "name": "UED设计师",
        "workspace": "~/.openclaw/workspace-ux-designer",
        "agentDir": "~/.openclaw/agents/ux-designer/agent"
      },
      {
        "id": "ui-designer",
        "name": "UI设计师",
        "workspace": "~/.openclaw/workspace-ui-designer",
        "agentDir": "~/.openclaw/agents/ui-designer/agent"
      },
      {
        "id": "backend-engineer",
        "name": "后端工程师",
        "workspace": "~/.openclaw/workspace-backend-engineer",
        "agentDir": "~/.openclaw/agents/backend-engineer/agent"
      },
      {
        "id": "database-engineer",
        "name": "数据库工程师",
        "workspace": "~/.openclaw/workspace-database-engineer",
        "agentDir": "~/.openclaw/agents/database-engineer/agent"
      },
      {
        "id": "frontend-engineer",
        "name": "前端工程师",
        "workspace": "~/.openclaw/workspace-frontend-engineer",
        "agentDir": "~/.openclaw/agents/frontend-engineer/agent"
      },
      {
        "id": "mobile-engineer",
        "name": "移动开发工程师",
        "workspace": "~/.openclaw/workspace-mobile-engineer",
        "agentDir": "~/.openclaw/agents/mobile-engineer/agent"
      },
      {
        "id": "qa-engineer",
        "name": "测试工程师",
        "workspace": "~/.openclaw/workspace-qa-engineer",
        "agentDir": "~/.openclaw/agents/qa-engineer/agent"
      },
      {
        "id": "ops-engineer",
        "name": "运维工程师",
        "workspace": "~/.openclaw/workspace-ops-engineer",
        "agentDir": "~/.openclaw/agents/ops-engineer/agent"
      },
      {
        "id": "data-analyst",
        "name": "数据分析师",
        "workspace": "~/.openclaw/workspace-data-analyst",
        "agentDir": "~/.openclaw/agents/data-analyst/agent"
      },
      {
        "id": "game-ops",
        "name": "游戏运营",
        "workspace": "~/.openclaw/workspace-game-ops",
        "agentDir": "~/.openclaw/agents/game-ops/agent"
      }
    ]
  },
  "bindings": [],
  "tools": {
    "agentToAgent": {
      "enabled": false,
      "allow": [
        "pm",
        "design",
        "dev",
        "ops",
        "blog",
        "project-manager",
        "product-manager",
        "system-architect",
        "domain-expert",
        "ux-designer",
        "ui-designer",
        "backend-engineer",
        "database-engineer",
        "frontend-engineer",
        "mobile-engineer",
        "qa-engineer",
        "ops-engineer",
        "data-analyst",
        "game-ops"
      ]
    }
  }
}