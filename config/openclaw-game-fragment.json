{
  "agents": {
    "defaults": {
      "compaction": {
        "mode": "safeguard"
      }
    },
    "list": [
      {
        "id": "game-master",
        "default": true,
        "name": "Game Master",
        "workspace": "~/.openclaw/workspace-game-master",
        "agentDir": "~/.openclaw/agents/game-master/agent"
      },
      {
        "id": "game-designer",
        "name": "Game Designer",
        "workspace": "~/.openclaw/workspace-game-designer",
        "agentDir": "~/.openclaw/agents/game-designer/agent"
      },
      {
        "id": "game-architect",
        "name": "Game Architect",
        "workspace": "~/.openclaw/workspace-game-architect",
        "agentDir": "~/.openclaw/agents/game-architect/agent"
      },
      {
        "id": "game-developer",
        "name": "Game Developer",
        "workspace": "~/.openclaw/workspace-game-developer",
        "agentDir": "~/.openclaw/agents/game-developer/agent"
      },
      {
        "id": "game-ops",
        "name": "Game Ops",
        "workspace": "~/.openclaw/workspace-game-ops",
        "agentDir": "~/.openclaw/agents/game-ops/agent"
      }
    ]
  },
  "bindings": [
    {
      "agentId": "game-master",
      "match": {
        "channel": "telegram"
      }
    },
    {
      "agentId": "game-master",
      "match": {
        "channel": "discord"
      }
    }
  ],
  "tools": {
    "agentToAgent": {
      "enabled": true,
      "allow": [
        "game-master",
        "game-designer",
        "game-architect",
        "game-developer",
        "game-ops"
      ]
    }
  }
}
